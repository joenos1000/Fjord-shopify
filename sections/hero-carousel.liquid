{%- comment -%}
  Fjord hero carousel
  - Full-bleed, 5 slides, dark cinematic style
  - Alpine.js carousel with fade transitions
  - Auto-play with pause on hover/touch
{%- endcomment -%}

<section
  x-data="{
    currentSlide: 0,
    totalSlides: {{ section.blocks.size }},
    autoplay: {{ section.settings.autoplay }},
    autoplaySpeed: {{ section.settings.autoplay_speed | times: 1000 }},
    timer: null,
    init() {
      if (this.autoplay && this.totalSlides > 1) this.startAutoplay();
    },
    startAutoplay() {
      this.stopAutoplay();
      this.timer = setInterval(() => this.next(), this.autoplaySpeed);
    },
    stopAutoplay() {
      if (this.timer) clearInterval(this.timer);
    },
    next() {
      this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
    },
    prev() {
      this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
    },
    goTo(index) {
      this.currentSlide = index;
      if (this.autoplay) this.startAutoplay();
    }
  }"
  @mouseenter="stopAutoplay()"
  @mouseleave="if (autoplay && totalSlides > 1) startAutoplay()"
  @touchstart.passive="stopAutoplay()"
  @touchend="if (autoplay && totalSlides > 1) startAutoplay()"
  class="relative w-full h-[70vh] lg:h-screen overflow-hidden"
>
  {%- for block in section.blocks -%}
    <div
      {% unless forloop.first %}x-cloak{% endunless %}
      x-show="currentSlide === {{ forloop.index0 }}"
      x-transition:enter="transition-opacity ease-out duration-500"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition-opacity ease-in duration-500"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="absolute inset-0 flex items-center"
      {{ block.shopify_attributes }}
    >
      {%- comment -%} Background image {%- endcomment -%}
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 1920 }}"
          srcset="
            {{ block.settings.image | image_url: width: 375 }} 375w,
            {{ block.settings.image | image_url: width: 768 }} 768w,
            {{ block.settings.image | image_url: width: 1200 }} 1200w,
            {{ block.settings.image | image_url: width: 1920 }} 1920w
          "
          sizes="100vw"
          alt="{{ block.settings.heading | escape }}"
          class="absolute inset-0 w-full h-full object-cover"
          {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
        >
      {%- else -%}
        <div class="absolute inset-0 bg-fjord-coffee"></div>
      {%- endif -%}

      {%- comment -%} Dark overlay {%- endcomment -%}
      <div class="absolute inset-0 bg-black/50"></div>

      {%- comment -%} Slide content {%- endcomment -%}
      <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12">
        {%- if block.settings.eyebrow != blank -%}
          <p class="font-ui text-xs sm:text-sm uppercase tracking-[0.2em] text-fjord-ivory/80 mb-4 lg:mb-6">
            {{ block.settings.eyebrow }}
          </p>
        {%- endif -%}

        {%- if block.settings.heading != blank -%}
          <h2 class="font-display text-4xl sm:text-6xl lg:text-7xl xl:text-8xl 2xl:text-9xl text-white leading-[0.9] mb-6 lg:mb-10 max-w-4xl">
            {{ block.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if block.settings.cta_label != blank -%}
          <a
            href="{{ block.settings.cta_url }}"
            class="btn-outline"
          >
            {{ block.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}

  {%- comment -%} Previous / Next arrows {%- endcomment -%}
  {%- if section.blocks.size > 1 -%}
    <button
      @click="prev(); if (autoplay) startAutoplay()"
      class="absolute left-4 lg:left-8 top-1/2 -translate-y-1/2 z-20 p-2 text-white/50 hover:text-white transition-colors duration-200"
      aria-label="{{ 'hero.previous_slide' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 lg:h-10 lg:w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <button
      @click="next(); if (autoplay) startAutoplay()"
      class="absolute right-4 lg:right-8 top-1/2 -translate-y-1/2 z-20 p-2 text-white/50 hover:text-white transition-colors duration-200"
      aria-label="{{ 'hero.next_slide' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 lg:h-10 lg:w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    {%- comment -%} Slide indicators {%- endcomment -%}
    <div class="absolute bottom-6 lg:bottom-10 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2">
      {%- for block in section.blocks -%}
        <button
          @click="goTo({{ forloop.index0 }})"
          :class="currentSlide === {{ forloop.index0 }} ? 'bg-fjord-camel w-8' : 'bg-white/40 w-3 hover:bg-white/60'"
          class="h-1 rounded-full transition-all duration-300"
          :aria-label="'{{ 'hero.go_to_slide' | t }}' + ' ' + {{ forloop.index }}"
          :aria-current="currentSlide === {{ forloop.index0 }} ? 'step' : false"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero Carousel",
  "tag": "section",
  "class": "fjord-hero-carousel",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Seconds per slide",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 6,
      "unit": "s"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button text",
          "default": "Se mere"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Brygget ved fjorden",
            "heading": "Fjord Øl",
            "cta_label": "Se vores øl"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Håndlavet på Mors",
            "heading": "Fjord Spiritus",
            "cta_label": "Se vores spiritus"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Vores historie",
            "heading": "Fjord Bryggeri & Destilleri",
            "cta_label": "Læs mere"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Oplev bryggeriet",
            "heading": "Book en rundvisning",
            "cta_label": "Book nu"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Hver fredag",
            "heading": "Fredagsbar & Fredagsfurter",
            "cta_label": "Se hvornår"
          }
        }
      ]
    }
  ]
}
{% endschema %}
