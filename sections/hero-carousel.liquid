{%- comment -%}
  Fjord hero carousel
  - Full-bleed, 5 slides, dark cinematic style
  - Alpine.js carousel with fade transitions
  - Auto-play with pause on hover/touch
{%- endcomment -%}

{%- comment -%} Override Dawn's section styling for full-bleed hero {%- endcomment -%}
<style>
  #shopify-section-{{ section.id }}.fjord-hero-carousel {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
  }
  #shopify-section-{{ section.id }} .fjord-hero {
    position: relative;
    width: 100%;
    height: 70svh;
    min-height: 42rem;
    overflow: hidden;
    isolation: isolate;
    background: #3C2313;
  }
  @supports not (height: 1svh) {
    #shopify-section-{{ section.id }} .fjord-hero {
      height: 70vh;
    }
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .fjord-hero {
      height: 100svh;
      min-height: 64rem;
    }
    @supports not (height: 1svh) {
      #shopify-section-{{ section.id }} .fjord-hero {
        height: 100vh;
      }
    }
  }
  #shopify-section-{{ section.id }} .fjord-hero__slide {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ section.id }} .fjord-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .fjord-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.50);
  }
  #shopify-section-{{ section.id }} .fjord-hero__fallback {
    position: absolute;
    inset: 0;
    background: #3C2313;
  }
  #shopify-section-{{ section.id }} .fjord-hero__content {
    position: relative;
    z-index: 10;
    height: 100%;
    width: min(80rem, 100%);
    margin: 0 auto;
    padding: calc(var(--header-height, 0px) + 2.4rem) 1.5rem 5.6rem;
    display: flex;
    align-items: flex-end;
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .fjord-hero__content {
      padding: calc(var(--header-height, 0px) + 3.2rem) 3rem 7.2rem;
    }
  }
  #shopify-section-{{ section.id }} .fjord-hero__eyebrow {
    font-family: 'Axia', Helvetica, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 249, 228, 0.8);
    margin-bottom: 1rem;
    font-size: 0.75rem;
  }
  #shopify-section-{{ section.id }} .fjord-hero__heading {
    font-family: 'Headline Gothic ATF', sans-serif;
    color: #FFF;
    line-height: 0.9;
    margin-bottom: 1.5rem;
    max-width: 56rem;
    font-size: clamp(2.5rem, 8vw, 9rem);
  }
  #shopify-section-{{ section.id }} .fjord-hero__cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 1px solid rgba(255, 249, 228, 0.8);
    color: #FFF9E4;
    font-family: 'Axia', Helvetica, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
  }
  #shopify-section-{{ section.id }} .fjord-hero__cta:hover {
    background: #A78952;
    border-color: #A78952;
    color: #fff;
  }
  #shopify-section-{{ section.id }} .fjord-hero__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    padding: 0.5rem;
    color: rgba(255, 255, 255, 0.72);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: color 0.2s;
  }
  #shopify-section-{{ section.id }} .fjord-hero__arrow:hover {
    color: #FFF;
  }
  #shopify-section-{{ section.id }} .fjord-hero__arrow--prev {
    left: 1rem;
  }
  #shopify-section-{{ section.id }} .fjord-hero__arrow--next {
    right: 1rem;
  }
  #shopify-section-{{ section.id }} .fjord-hero__indicators {
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  #shopify-section-{{ section.id }} .fjord-hero__indicator {
    height: 0.25rem;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    background: rgba(255, 255, 255, 0.5);
    width: 0.75rem;
  }
  #shopify-section-{{ section.id }} .fjord-hero__indicator.is-active {
    width: 2rem;
    background: #A78952;
  }
</style>

<div
  x-data="{
    currentSlide: 0,
    totalSlides: {{ section.blocks.size | json }},
    autoplay: {{ section.settings.autoplay | json }},
    autoplaySpeed: {{ section.settings.autoplay_speed | times: 1000 | json }},
    timer: null,
    init() {
      if (this.autoplay && this.totalSlides > 1) this.startAutoplay();
    },
    startAutoplay() {
      this.stopAutoplay();
      this.timer = setInterval(() => this.next(), this.autoplaySpeed);
    },
    stopAutoplay() {
      if (this.timer) clearInterval(this.timer);
    },
    next() {
      if (this.totalSlides < 1) return;
      this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
    },
    prev() {
      if (this.totalSlides < 1) return;
      this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
    },
    goTo(index) {
      this.currentSlide = index;
      if (this.autoplay) this.startAutoplay();
    }
  }"
  @mouseenter="stopAutoplay()"
  @mouseleave="if (autoplay && totalSlides > 1) startAutoplay()"
  @touchstart.passive="stopAutoplay()"
  @touchend="if (autoplay && totalSlides > 1) startAutoplay()"
  class="fjord-hero"
>
  {%- for block in section.blocks -%}
    <div
      {% unless forloop.first %}x-cloak{% endunless %}
      x-show="currentSlide === {{ forloop.index0 }}"
      x-transition:enter="transition-opacity ease-out duration-500"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition-opacity ease-in duration-500"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fjord-hero__slide"
      {{ block.shopify_attributes }}
    >
      {%- comment -%} Background image {%- endcomment -%}
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 1920 }}"
          srcset="
            {{ block.settings.image | image_url: width: 375 }} 375w,
            {{ block.settings.image | image_url: width: 768 }} 768w,
            {{ block.settings.image | image_url: width: 1200 }} 1200w,
            {{ block.settings.image | image_url: width: 1920 }} 1920w
          "
          sizes="100vw"
          alt="{{ block.settings.heading | escape }}"
          class="fjord-hero__bg"
          {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
        >
      {%- else -%}
        <div class="fjord-hero__fallback"></div>
      {%- endif -%}

      {%- comment -%} Dark overlay {%- endcomment -%}
      <div class="fjord-hero__overlay"></div>

      {%- comment -%} Slide content {%- endcomment -%}
      <div class="fjord-hero__content">
        <div>
          {%- if block.settings.eyebrow != blank -%}
            <p class="fjord-hero__eyebrow">
              {{ block.settings.eyebrow }}
            </p>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h2 class="fjord-hero__heading">
              {{ block.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if block.settings.cta_label != blank -%}
            <a
              href="{{ block.settings.cta_url }}"
              class="fjord-hero__cta"
            >
              {{ block.settings.cta_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endfor -%}

  {%- comment -%} Previous / Next arrows {%- endcomment -%}
  {%- if section.blocks.size > 1 -%}
    <button
      @click="prev(); if (autoplay) startAutoplay()"
      class="fjord-hero__arrow fjord-hero__arrow--prev"
      aria-label="{{ 'general.slider.previous_slide' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <button
      @click="next(); if (autoplay) startAutoplay()"
      class="fjord-hero__arrow fjord-hero__arrow--next"
      aria-label="{{ 'general.slider.next_slide' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    {%- comment -%} Slide indicators {%- endcomment -%}
    <div class="fjord-hero__indicators">
      {%- for block in section.blocks -%}
        <button
          @click="goTo({{ forloop.index0 }})"
          class="fjord-hero__indicator"
          :class="{ 'is-active': currentSlide === {{ forloop.index0 }} }"
          aria-label="{{ 'general.slider.name' | t }} {{ forloop.index }}"
          :aria-current="currentSlide === {{ forloop.index0 }} ? 'step' : false"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero Carousel",
  "tag": "div",
  "class": "fjord-hero-carousel",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Seconds per slide",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 6,
      "unit": "s"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button text",
          "default": "Se mere"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Brygget ved fjorden",
            "heading": "Fjord Øl",
            "cta_label": "Se vores øl"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Håndlavet på Mors",
            "heading": "Fjord Spiritus",
            "cta_label": "Se vores spiritus"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Vores historie",
            "heading": "Fjord Bryggeri & Destilleri",
            "cta_label": "Læs mere"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Oplev bryggeriet",
            "heading": "Book en rundvisning",
            "cta_label": "Book nu"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Hver fredag",
            "heading": "Fredagsbar & Fredagsfurter",
            "cta_label": "Se hvornår"
          }
        }
      ]
    }
  ]
}
{% endschema %}
