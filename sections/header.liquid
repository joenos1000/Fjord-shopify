{%- comment -%}
  Fjord global header
  - Transparent on hero, solid fjord-coffee on scroll
  - Desktop: left nav (from Shopify menu), center logo, right cart
  - Mobile: hamburger → slide-in panel
{%- endcomment -%}

{%- liquid
  assign menu = linklists[section.settings.menu]
-%}

<div
  x-data="{ scrolled: false, mobileMenuOpen: false }"
  @scroll.window="scrolled = window.scrollY > 50"
>
  <header
    class="fixed top-0 left-0 w-full z-50 transition-all duration-200"
    :class="scrolled ? 'bg-fjord-coffee shadow-lg' : 'bg-transparent'"
  >
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-20">

        {%- comment -%} Mobile hamburger (left, mobile only) {%- endcomment -%}
        <button
          @click="mobileMenuOpen = true"
          class="lg:hidden text-fjord-ivory p-2 -ml-2"
          aria-label="{{ 'header.menu' | t }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        {%- comment -%} Desktop nav (left) {%- endcomment -%}
        <nav class="hidden lg:flex items-center gap-8" aria-label="{{ 'header.menu' | t }}">
          {%- for link in menu.links -%}
            <a
              href="{{ link.url }}"
              class="font-ui text-xs uppercase tracking-[0.15em] text-fjord-ivory/90 hover:text-fjord-camel transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-fjord-camel after:transition-all after:duration-200 hover:after:w-full{% if link.active %} text-fjord-camel after:w-full{% endif %}"
            >
              {{ link.title }}
            </a>
          {%- endfor -%}
        </nav>

        {%- comment -%} Center logo {%- endcomment -%}
        <a href="{{ routes.root_url }}" class="absolute left-1/2 -translate-x-1/2">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: height: 48 }}"
              srcset="{{ section.settings.logo | image_url: height: 48 }} 1x, {{ section.settings.logo | image_url: height: 96 }} 2x"
              alt="{{ shop.name }}"
              class="h-8 lg:h-12 w-auto"
              loading="eager"
            >
          {%- else -%}
            <span class="font-display text-xl lg:text-2xl text-fjord-ivory tracking-wide">Fjord</span>
          {%- endif -%}
        </a>

        {%- comment -%} Cart (right) {%- endcomment -%}
        <a
          href="{{ routes.cart_url }}"
          class="flex items-center gap-2 text-fjord-ivory/90 hover:text-fjord-camel transition-colors duration-200"
        >
          <span class="font-ui text-xs uppercase tracking-[0.15em] hidden sm:inline">
            {{ section.settings.cart_label }}
          </span>
          <span class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            {%- if cart.item_count > 0 -%}
              <span class="absolute -top-1.5 -right-1.5 bg-fjord-camel text-white text-[10px] font-ui w-4 h-4 rounded-full flex items-center justify-center">
                {{ cart.item_count }}
              </span>
            {%- endif -%}
          </span>
        </a>

      </div>
    </div>
  </header>

  {%- comment -%} Mobile menu overlay {%- endcomment -%}
  <div
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="mobileMenuOpen = false"
    class="fixed inset-0 bg-black/60 z-[60] lg:hidden"
    x-cloak
  ></div>

  {%- comment -%} Mobile menu panel {%- endcomment -%}
  <nav
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-300 transform"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200 transform"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    class="fixed top-0 left-0 w-80 max-w-[85vw] h-full bg-fjord-coffee z-[70] p-8 lg:hidden overflow-y-auto"
    x-cloak
    aria-label="{{ 'header.menu' | t }}"
  >
    <div class="flex items-center justify-between mb-12">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: height: 40 }}"
          alt="{{ shop.name }}"
          class="h-8 w-auto"
        >
      {%- else -%}
        <span class="font-display text-xl text-fjord-ivory">Fjord</span>
      {%- endif -%}

      <button
        @click="mobileMenuOpen = false"
        class="text-fjord-ivory p-2 -mr-2"
        aria-label="{{ 'header.close_menu' | t }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex flex-col gap-6">
      {%- for link in menu.links -%}
        <a
          href="{{ link.url }}"
          class="font-ui text-sm uppercase tracking-[0.2em] text-fjord-ivory/90 hover:text-fjord-camel transition-colors duration-200{% if link.active %} text-fjord-camel{% endif %}"
          @click="mobileMenuOpen = false"
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    </div>

    {%- comment -%} Mobile cart link {%- endcomment -%}
    <div class="mt-12 pt-8 border-t border-fjord-ivory/20">
      <a
        href="{{ routes.cart_url }}"
        class="flex items-center gap-3 font-ui text-sm uppercase tracking-[0.2em] text-fjord-ivory/90 hover:text-fjord-camel transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        {{ section.settings.cart_label }}
        {%- if cart.item_count > 0 -%}
          <span class="bg-fjord-camel text-white text-[10px] font-ui w-5 h-5 rounded-full flex items-center justify-center">
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>
    </div>
  </nav>
</div>

{%- comment -%} Structured data {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if section.settings.logo %}
      "logo": {{ section.settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Header",
  "class": "fjord-header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Cart"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart label",
      "default": "Kurv"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
